                "terminal.ansi.bright_yellow": "#c77f5fff",
                "terminal.ansi.bright_blue": "#cc7c5eff",
                "terminal.ansi.bright_magenta": "#fa5a46ff",
                "terminal.ansi.bright_cyan": "#c77e65ff",
